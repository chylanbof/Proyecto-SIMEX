<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Fila superior: Avatar + ID + Subtítulo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Avatar circular con letra -->
            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ic_persona"
                android:gravity="center"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvIdPedido"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="EC001"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <TextView
                    android:id="@+id/tvTipoPedido"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Exportacion Maritima"
                    android:textSize="13sp"
                    android:textColor="#777777"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="12dp"/>

        <!-- Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado: "
                android:textSize="13sp"
                android:textColor="#555555"/>

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="En tramite"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

        </LinearLayout>

        <!-- Método de envío -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Metodo de Envio: "
                android:textSize="13sp"
                android:textColor="#555555"/>

            <TextView
                android:id="@+id/tvMetodoEnvio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="DHL Express"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

        </LinearLayout>

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerMas"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver mas"
                android:textColor="#1A1A1A"
                app:strokeColor="#CCCCCC"
                app:cornerRadius="20dp"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTracking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tracking"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF6D00"
                app:cornerRadius="20dp"/>

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>