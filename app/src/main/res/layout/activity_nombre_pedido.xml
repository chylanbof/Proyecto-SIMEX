<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <include
        android:id="@+id/layoutDeArriba"
        layout="@layout/boton_comun_pantallas" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutDeArriba"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Card 1: Número de oferta -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDetalles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Detalles"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:gravity="center"
                        android:paddingTop="12dp"
                        android:paddingBottom="8dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/imgLogoNaviera"
                            android:layout_width="80dp"
                            android:layout_height="40dp"
                            android:src="@drawable/icono"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="16dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Numero de oferta:"
                                android:textSize="14sp"
                                android:textColor="#555555"/>

                            <TextView
                                android:id="@+id/tvNumeroOferta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="EC002"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A1A"/>

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Detalles del envío -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSolicitud"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvTituloSolicitud"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Nueva solicitud de Textil SA"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Cliente -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cliente:"
                            android:textSize="13sp"
                            android:textColor="#555555"/>
                        <TextView
                            android:id="@+id/tvCliente"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            tools:text="Maria Garcia - Moda Express"
                            android:textSize="13sp"
                            android:textColor="#1A1A1A"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Ruta -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ruta:"
                            android:textSize="13sp"
                            android:textColor="#555555"/>
                        <TextView
                            android:id="@+id/tvRuta"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            tools:text="Barcelona - NY"
                            android:textSize="13sp"
                            android:textColor="#1A1A1A"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Modo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Modo:"
                            android:textSize="13sp"
                            android:textColor="#555555"/>
                        <TextView
                            android:id="@+id/tvModo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            tools:text="Aereo"
                            android:textSize="13sp"
                            android:textColor="#1A1A1A"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Peso -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Peso:"
                            android:textSize="13sp"
                            android:textColor="#555555"/>
                        <TextView
                            android:id="@+id/tvPeso"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            tools:text="12.400 kg"
                            android:textSize="13sp"
                            android:textColor="#1A1A1A"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Incoterm -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Incoterm:"
                            android:textSize="13sp"
                            android:textColor="#555555"/>
                        <TextView
                            android:id="@+id/tvIncoterm"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            tools:text="FOB"
                            android:textSize="13sp"
                            android:textColor="#1A1A1A"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Urgencia -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Urgencia:"
                            android:textSize="13sp"
                            android:textColor="#555555"/>
                        <TextView
                            android:id="@+id/tvUrgencia"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            tools:text="Alta - antes 30 Feb"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#E65100"
                            android:gravity="end"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botón Descargar PDF -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDescargarPdf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="32dp"
                android:text="Descargar Pdf"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#FF6D00"
                app:icon="@drawable/ic_download_white"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp"
                app:cornerRadius="24dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>