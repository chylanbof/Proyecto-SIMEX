<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <include
        android:id="@+id/layoutDeArriba"
        layout="@layout/boton_comun" />

    <!-- Fila de estados -->
    <LinearLayout
        android:id="@+id/layoutEstados"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutDeArriba"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <!-- En preparación -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="169dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/enPreparacion"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/preparacion"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"/>

            <TextView
                android:id="@+id/numero2"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/badge_background"/>

        </FrameLayout>

        <!-- En tránsito -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="169dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/enTransito"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:src="@drawable/transito"/>

            <TextView
                android:id="@+id/numero1"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/badge_background"/>

        </FrameLayout>

        <!-- Entregado -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="169dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/enTregado"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/entregado"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"/>

            <TextView
                android:id="@+id/numero3"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/badge_background"/>

        </FrameLayout>

    </LinearLayout>

    <!-- Tarjetas-->
    <LinearLayout
        android:id="@+id/layoutTarjetas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="3dp"
        app:layout_constraintTop_toBottomOf="@id/layoutEstados"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Tarjeta Resumen -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResumen"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTituloResumen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resumen"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvSubtituloResumen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="En reparto 0"
                        android:textSize="14sp"/>

                </LinearLayout>

                <ImageView
                    android:id="@+id/ivIconoResumen"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:src="@drawable/ic_resumen"
                    android:scaleType="fitCenter"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Tarjeta Ofertas -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardOfertas"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTituloOfertas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ofertas"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvSubtituloOfertas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Ofertas Disponibles"
                        android:textSize="14sp"/>

                </LinearLayout>

                <ImageView
                    android:id="@+id/ivIconoOfertas"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:src="@drawable/ic_ofertas"
                    android:scaleType="fitCenter"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Tarjeta Historial -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardHistorial"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTituloHistorial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Historial"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvSubtituloHistorial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Pedidos Guardados"
                        android:textSize="14sp"/>

                </LinearLayout>

                <ImageView
                    android:id="@+id/ivIconoHistorial"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:src="@drawable/ic_historial"
                    android:scaleType="fitCenter"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>