<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/llButtonsEstadoIncoterms"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardOferta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvTituloDetalle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detalle de Oferta"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FD7121"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginVertical="12dp"/>

                    <TextView
                        android:id="@+id/tvDetalleOrigen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Origen: -"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvDetalleDestino"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Destino: -"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvDetalleIncoterm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Incoterm: -"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="8dp"/>

                    <TextView
                        android:id="@+id/tvDetallePeso"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Peso: - kg"
                        android:textSize="15sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvDetalleVolumen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Volumen: "
                        android:textSize="15sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvDetalleTransportista"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Transportista: -"
                        android:textSize="15sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvDetalleContenedor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Contenedor: -"
                        android:textSize="15sp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estados del Seguimiento (Incoterm)"
                android:layout_marginTop="24dp"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#666666"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvIncotermsEstados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_incoterms" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comentarios del Agente"
                android:layout_marginTop="20dp"
                android:textStyle="bold"
                android:textColor="#666666"/>

            <TextView
                android:id="@+id/tvNotasComercial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:text="-"
                android:padding="12dp"
                android:background="#FFFFFF"
                android:elevation="2dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/llButtonsEstadoIncoterms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#F8F9FA"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnCancelarEstado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Cancelar"
            android:textColor="@color/black"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btnGuardarEstado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Guardar"
            android:textColor="@color/white"
            app:backgroundTint="#FD7121" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>