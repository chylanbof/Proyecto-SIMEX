<?xml version="1.0" encoding="utf-8"?>

<!-- card que se encargara de llenar las ofertas -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvIdOfertaUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IdOferta"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FD7121"
                android:layout_alignParentStart="true"/>

            <TextView
                android:id="@+id/tvEstadoOferta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESTADO"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_alignParentEnd="true"
                android:background="#666666"
                android:visibility="gone"
                tools:visibility="visible"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/tvRutaUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Origen -> Destino"
            android:textSize="14sp"
            android:textColor="#000000"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvIncotermUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Incoterm"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>