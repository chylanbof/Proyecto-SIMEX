<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:paddingHorizontal="4dp">

    <!-- Icono + línea -->
    <LinearLayout
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/ivEstadoIcono"
            android:layout_width="24dp"
            android:layout_height="24dp"/>

        <View
            android:id="@+id/lineaVertical"
            android:layout_width="2dp"
            android:layout_height="40dp"
            android:background="#CCCCCC"/>

    </LinearLayout>

    <!-- Contenido -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp">

        <TextView
            android:id="@+id/tvEstadoPaso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_estado_paso"/>

        <TextView
            android:id="@+id/tvNombrePaso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginTop="4dp"/>

        <!-- Botones solo visibles en modo edición -->
        <LinearLayout
            android:id="@+id/layoutBotonesEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPendiente"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Pendiente"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                app:strokeColor="#BDBDBD"
                app:cornerRadius="16dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnProceso"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="En proceso"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                app:strokeColor="#FF6D00"
                app:cornerRadius="16dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinalizado"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Finalizado"
                android:textSize="11sp"
                android:backgroundTint="#4CAF50"
                app:cornerRadius="16dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>